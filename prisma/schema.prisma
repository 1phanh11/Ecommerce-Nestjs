// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output  = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING // Vừa tạo, chờ xác nhận
  CONFIRMED // Đã xác nhận, đang chuẩn bị
  SHIPPED // Đang giao
  DELIVERED // Đã giao thành công
  CANCELLED // Đã hủy
}

// ─── MODELS ─────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String // Lưu trữ mật khẩu đã được hash
  name         String
  role         Role     @default(USER)
  refreshToken String? // Lưu trữ refresh token cho JWT và Nullable vì không phải lúc nào cũng có do login/logout
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  price       Float
  stock       Int         @default(0)
  images      String[] // Lưu trữ URL hình ảnh sản phẩm
  category    Category    @relation(fields: [categoryId], references: [id])
  categoryId  String
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([name])
  @@index([price])
  @@index([categoryId])
}

model Order {
  id     String      @id @default(cuid())
  status OrderStatus @default(PENDING)
  total  Float //snapshot tổng giá trị đơn hàng tại thời điểm đặt hàng
  user   User        @relation(fields: [userId], references: [id])
  userId String

  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id       String @id @default(cuid())
  quantity Int
  price    Float //snapshot giá tại thời điểm mua

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@index([orderId])
  @@index([productId])
}
